# Supabase (frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Bot username without @ (example: my_cicle_bot)
VITE_BOT_USERNAME=my_cicle_bot
# Mini App short name from BotFather Direct Link: t.me/<bot>/<slug>
VITE_MINI_APP_SLUG=MyCycle

# Telegram / Supabase Edge secrets (set via `supabase secrets set`, not Vite)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
WEBHOOK_SECRET=long-random-string
